# Copy to `.env` in this folder (repo root) for local dev with remote Postgres.
# You can use the same "External Database URL" as on Render.

PORT=3001

DATABASE_URL=postgresql://USER:PASSWORD@HOST.region-postgres.render.com/DATABASE
# DB_URL=postgresql://USER:PASSWORD@HOST.region-postgres.render.com/DATABASE

SESSION_SECRET=change-me-for-local

# Optional: CORS if the UI is on another origin
# ALLOWED_ORIGINS=http://localhost:3001
